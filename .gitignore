.DS_Store
.DS_Store?
._*
Thumbs.db

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Environment and secrets — NEVER commit these
.env
.env.*
*.pem
*.key
*.crt
*.cert
secrets/

# Logs
*.log
logs/

# Test coverage
coverage/
*.profraw
*.profdata
